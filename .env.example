# .env.example
# ============================================================================
# VIRALSTICKERAI.COM - ENVIRONMENT VARIABLES
# ============================================================================
# Copy this file to .env.local and fill in the actual values

# ============================================================================
# SUPABASE
# ============================================================================
# Get these from your Supabase project dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here

# Service role key (for server-side operations only - KEEP SECRET)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================================================
# STRIPE
# ============================================================================
# Get these from your Stripe Dashboard
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your-publishable-key-here
STRIPE_SECRET_KEY=sk_live_your-secret-key-here

# Stripe Webhook Secret (for webhook validation)
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret-here

# ============================================================================
# NEXT.JS & DEPLOYMENT
# ============================================================================
# Vercel deployment URL (or your custom domain)
NEXT_PUBLIC_APP_URL=https://viralstickerai.com
VERCEL_URL=https://viralstickerai.com

# Environment (development, staging, production)
NODE_ENV=production

# ============================================================================
# OPTIONAL: EMAIL & NOTIFICATIONS
# ============================================================================
# SMTP configuration for transactional emails (order confirmations, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password-here
SMTP_FROM_EMAIL=noreply@viralstickerai.com

# ============================================================================
# OPTIONAL: ANALYTICS & MONITORING
# ============================================================================
# Google Analytics or similar
NEXT_PUBLIC_ANALYTICS_ID=

# Sentry for error monitoring
SENTRY_AUTH_TOKEN=

# ============================================================================
# OPTIONAL: EXTERNAL SERVICES
# ============================================================================
# Google Maps API (if using map-based shipping zones)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ============================================================================
# SECURITY
# ============================================================================
# Secret key for session encryption (generate with: openssl rand -hex 32)
SESSION_SECRET=your-session-secret-here-min-32-chars

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,https://viralstickerai.com
